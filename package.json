{
  "name": "ramonmota",
  "homepage": "https://ramonmota.github.io/portfolio/",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "icomoon-react": "2.0.19",
    "lucide-react": "^1.21.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router": "5.2.0",
    "react-router-dom": "5.2.0",
    "react-scripts": "5.0.1",
    "sass": "1.52.3",
    "web-vitals": "1.1.0"
  },
  "scripts": {
    "start": "concurrently \"npm:tailwind:watch\" \"react-scripts start\"",
    "prebuild": "npm run tailwind:build",
    "build": "react-scripts build",
    "tailwind:build": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind.generated.css --minify",
    "tailwind:watch": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind.generated.css --watch",
    "deploy": "gh-pages -d build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/react": "18.0.12",
    "@types/react-dom": "18.0.5",
    "@types/react-router-dom": "5.3.3",
    "concurrently": "^10.0.3",
    "gh-pages": "^6.1.1",
    "tailwindcss": "^4.3.1"
  }
}
